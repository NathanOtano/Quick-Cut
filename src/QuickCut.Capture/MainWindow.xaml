<Window x:Class="QuickCut.Capture.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="QuickCut"
        MinHeight="620"
        MinWidth="920"
        Height="640"
        Width="980"
        Background="{DynamicResource QuickCut.WindowBackgroundBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="QuickCut"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource QuickCut.TextBrush}" />
            <TextBlock Text="Capture locale, presse-papier et annotation rapide"
                       Margin="0,4,0,0"
                       Foreground="{DynamicResource QuickCut.MutedTextBrush}" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,28,0,24"
                Padding="20"
                Background="{DynamicResource QuickCut.PanelBackgroundBrush}"
                BorderBrush="{DynamicResource QuickCut.BorderBrush}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Button x:Name="CaptureButton"
                            Content="Capturer"
                            Height="40"
                            Margin="0,0,0,12"
                            Click="CaptureButton_Click"
                            ToolTip="Même action que Win + &lt; ou AltGr + Impr. écran : affiche l'overlay sombre et lance la sélection. Maintiens Maj pour copier seulement dans le presse-papier." />
                    <Button x:Name="OpenJobsButton"
                            Content="Ouvrir les captures"
                            Height="40"
                            Margin="0,0,0,12"
                            Click="OpenJobsButton_Click"
                            ToolTip="Ouvre le dossier local où QuickCut écrit les captures." />
                    <Button x:Name="OpenImageButton"
                            Content="Ouvrir une image"
                            Height="40"
                            Margin="0,0,0,12"
                            Click="OpenImageButton_Click"
                            ToolTip="Choisit une image à annoter, en commençant dans le dossier des captures." />
                    <Button x:Name="OpenLastImageButton"
                            Content="Annoter l'image"
                            Height="40"
                            Margin="0,0,0,16"
                            IsEnabled="False"
                            Click="OpenLastImageButton_Click"
                            ToolTip="Ouvre la dernière capture dans l'aperçu QuickCut avec outils d'annotation." />
                    <CheckBox x:Name="StartupCheckBox"
                              Content="Démarrer avec Windows"
                              Checked="StartupCheckBox_Changed"
                              Unchecked="StartupCheckBox_Changed"
                              ToolTip="Lance un petit écouteur invisible au démarrage pour que le raccourci puisse ouvrir QuickCut même si l'app n'est pas déjà lancée." />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="24,0,0,0">
                    <TextBlock Text="État"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource QuickCut.TextBrush}" />
                    <TextBlock x:Name="StatusText"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource QuickCut.TextBrush}" />
                    <TextBlock x:Name="LastJobText"
                               Margin="0,18,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource QuickCut.MutedTextBrush}" />
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="Win + &lt; ou AltGr + Impr. écran lancent la capture. Avec Démarrer avec Windows, un écouteur invisible peut ouvrir QuickCut même si l'app principale n'est pas déjà lancée. Maintiens Maj pendant la capture pour copier seulement dans le presse-papier, sans fichier. Le bouton Capturer reste disponible si Windows réserve un raccourci."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource QuickCut.MutedTextBrush}" />
    </Grid>
</Window>
